@page "/"

@using System.Net.Http.Json

<h1>Exchange Rates</h1>

<table class="table">
    <thead>
        <tr>
            <th>Currency</th>
            <th>Buy</th>
            <th>Sell</th>
            <th></th>
        </tr>
    </thead>

    <tbody>
        @foreach (var rate in rates)
        {
            <tr>
                <td>
                    @rate.CurrencyCode
                </td>

                <td>
                    <input type="number"
                           @bind="rate.BuyRate" />
                </td>

                <td>
                    <input type="number"
                           @bind="rate.SellRate" />
                </td>

                <td>
                    <button @onclick="() => Save(rate)">
                        Save
                    </button>
                </td>
            </tr>
        }
    </tbody>
</table>

@code
{
    private readonly
        HttpClient _http =
            new();

    private List<ExchangeRate>
        rates = new();

    protected override async Task
        OnInitializedAsync()
    {
        _http.BaseAddress =
            new Uri(
                "https://localhost:7174");

        await LoadRates();
    }

    private async Task
        LoadRates()
    {
        rates =
            await _http
                .GetFromJsonAsync<
                    List<ExchangeRate>>(
                        "/api/exchange")
            ?? new();
    }

    private async Task
        Save(
            ExchangeRate rate)
    {
        await _http.PutAsync(
            $"/api/exchange/{rate.CurrencyCode}" +
            $"?buyRate={rate.BuyRate}" +
            $"&sellRate={rate.SellRate}",
            null);
    }

    public class ExchangeRate
    {
        public string CurrencyCode
        { get; set; }
            = string.Empty;

        public decimal BuyRate
        { get; set; }

        public decimal SellRate
        { get; set; }
    }
}