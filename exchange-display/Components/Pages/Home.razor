@page "/"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@implements IAsyncDisposable

@using System.Net.Http.Json
@using Microsoft.AspNetCore.SignalR.Client

<h1>Exchange Rates</h1>

<table class="table">
    <thead>
        <tr>
            <th>Currency</th>
            <th>Buy</th>
            <th>Sell</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var rate in rates)
        {
            <tr>
                <td>@rate.CurrencyCode</td>
                <td>@rate.BuyRate</td>
                <td>@rate.SellRate</td>
            </tr>
        }
    </tbody>
</table>

@code
{
    private readonly
        HttpClient _http =
            new();

    private HubConnection? hub;

    private List<ExchangeRate>
        rates = new();

    /// <summary>
    /// Хуудас ачаалагдах үед валютын ханшийг татаж, SignalR холболтыг тохируулна.
    /// </summary>
    protected override async Task
        OnInitializedAsync()
    {
        _http.BaseAddress =
            new Uri(
                "https://localhost:7174");

        await LoadRates();

        hub =
            new HubConnectionBuilder()
                .WithUrl(
                    "https://localhost:7174/exchangeHub")
                .WithAutomaticReconnect()
                .Build();

        hub.On(
            "ExchangeUpdated",
            async () =>
            {
                await LoadRates();

                await InvokeAsync(
                    StateHasChanged);
            });

        await hub.StartAsync();
    }

    /// <summary>
    /// Серверээс хамгийн сүүлийн үеийн валютын ханшийг ачаална.
    /// </summary>
    private async Task
        LoadRates()
    {
        rates =
            await _http
                .GetFromJsonAsync<
                    List<ExchangeRate>>(
                        "/api/exchange")
            ?? new();
    }

    /// <summary>
    /// Хуудсыг хаах үед SignalR холболтыг салгаж нөөцийг чөлөөлнө.
    /// </summary>
    public async ValueTask
        DisposeAsync()
    {
        if (hub is not null)
        {
            await hub
                .DisposeAsync();
        }
    }

    public class ExchangeRate
    {
        public string CurrencyCode
        { get; set; }
            = string.Empty;

        public decimal BuyRate
        { get; set; }

        public decimal SellRate
        { get; set; }
    }
}